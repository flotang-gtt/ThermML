<database
        xmlns="http://calphad.org/thermml/0.1"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:xi="http://www.w3.org/2001/XInclude"
        xsi:schemaLocation="http://calphad.org/thermml/0.1 ../schema/thermml-schema.xsd"
        name="Example Simple Solution Database">

    <metadata>
        <title>Example Simple Solution Database</title>
        <version>1.0</version>
        <description>This is an example thermodynamic database for demonstrating the ThermML schema for simple solutions.</description>
        <license/>
        <authors/>
        <created/>
        <revisions/>
        <references/>
    </metadata>

    <nonChemicalPotentials>
        <nonChemicalPotential id="potT" symbol="T" units="K"/>
        <nonChemicalPotential id="potP" symbol="P" units="bar"/>
        <nonChemicalPotential id="potB" symbol="B" units="T"/>
    </nonChemicalPotentials>

    <systemComponents>
        <systemComponent symbol="Va" />
        <systemComponent symbol="C"  refstate="GRAPHITE" molarMass="12.011"  h298="1054.0"   s298="5.7423"  />
        <systemComponent symbol="Fe" refstate="BCC_A2"   molarMass="55.847"  h298="4489.0"   s298="27.2797" />
        <systemComponent symbol="Mn" refstate="CBCC_A12" molarMass="54.9380" h298="4995.696" s298="32.2206" />
    </systemComponents>

    <phases>
        <phase xsi:type="CEFPhaseType" name="FCC_A1" alias="Austenite" state="solid">
            <description>There should be a valid, extensive description of this phase in clear language.</description>

            <species>
                <specie name="Fe" composition="Fe"/>
                <specie name="Mn" composition="Mn"/>
                <specie name="C" composition="C"/>
                <specie name="Va" composition="Va"/>
            </species>

            <structure>
                <sublattices multiplicities="1.0 1.0">
                    <site constituents="Fe Mn"/>
                    <site constituents="C Va"/>
                </sublattices>

                <crystallographic xsi:type="CrystalInformationType">
                    <spacegroup>225</spacegroup>
                    <prototype>225</prototype>
                    <site constituents="Fe Mn" wyckoff="4a"/>
                    <site constituents="C Va" wyckoff="4b"/>
                    <map>
                        <site from="4a" to="1"/>
                        <site from="4b" to="2"/>
                    </map>
                </crystallographic>
            </structure>

            <endmembers>
                <endmember name="FeVa">
                    <description>A phase description of pure iron - the austenitic phase.</description>
                    <constituents>
                        <site><const species="Fe"/></site>
                        <site><const species="Va"/></site>
                    </constituents>
                    <property xsi:type="G">
                        <ref>91Din</ref>
                        <expr>Fe#FCC_A1</expr>
                    </property>
                    <property xsi:type="M">
                        <ref>91Din</ref>
                        <comment>This is not the correct value.</comment>
                        <temperature type="Neel">1043.0</temperature>
                        <moment>3.0</moment>
                    </property>
                </endmember>
                <endmember name="MnVa">
                    <constituents>
                        <site><const species="Mn"/></site>
                        <site><const species="Va"/></site>
                    </constituents>
                    <property xsi:type="G">
                        <ref>91Din</ref>
                        <expr>Mn#FCC_A1</expr>
                    </property>
                </endmember>
                <endmember name="FeC">
                    <description>This is not a stable endmember.</description>
                    <constituents>
                        <site><const species="Fe"/></site>
                        <site><const species="C"/></site>
                    </constituents>
                    <property xsi:type="G">
                        <ref>85Gus</ref>
                        <comment>This parameter is not great. Check the TDB!</comment>
                        <expr>Fe#FCC_A1  +  C#HSER  +  77207  +  -15.877*T</expr>
                    </property>
                </endmember>
                <endmember name="MnC">
                    <constituents>
                        <site><const species="Mn"/></site>
                        <site><const species="C"/></site>
                    </constituents>
                    <property xsi:type="G">
                        <ref>10Dju</ref>
                        <expr>+Mn#HSER  +  C#HSER  +  13.659*T</expr>
                    </property>
                </endmember>
            </endmembers>

            <interactions>
                <interaction name="Fe:C,Va">
                    <constituents>
                        <site><const species="Fe"/></site>
                        <site><const species="C"/><const species="Va"/></site>
                    </constituents>
                    <property xsi:type="L">
                        <ref>91Din</ref>
                        <expr rank="0">7099.0  +  123*T</expr>
                        <expr rank="1">22*T</expr>
                    </property>
                    <property xsi:type="BML">
                        <ref>91Din</ref>
                        <expr rank="0">7099.0  +  123*T</expr>
                    </property>
                </interaction>
                <interaction name="Fe,Mn:Va">
                    <constituents>
                        <site><const species="Fe"/><const species="Mn"/></site>
                        <site><const species="Va"/></site>
                    </constituents>
                    <property xsi:type="L">
                        <ref>91Din</ref>
                        <expr rank="0">4000.0</expr>
                        <expr rank="1">22*T</expr>
                    </property>
                    <property xsi:type="BML">
                        <ref>91Din</ref>
                        <expr rank="0">7099.0  +  123*T</expr>
                    </property>
                </interaction>
                <interaction name="Mn:C,Va">
                    <constituents>
                        <site><const species="Mn"/></site>
                        <site><const species="C"/><const species="Va"/></site>
                    </constituents>
                    <property xsi:type="L">
                        <ref>91Din</ref>
                        <expr rank="0">-992.22</expr>
                    </property>
                    <property xsi:type="BML">
                        <ref>91Din</ref>
                        <expr rank="0">7099.0+123*T</expr>
                    </property>
                </interaction>
            </interactions>
        </phase>

    </phases>

    <globalExpressions>
        <expression name="Fe#HSER" xsi:type="RangedTemperatureExpr">
            <range low="298.15" high="1811.0" >
                  1225.7  +  124.134*T  +  -23.5143*T*LN(T)  +  -0.00439752*T**2  +  -5.8927E-08*T**3  +  77359*T**(-1)
            </range>
            <range low="1811.0" high="6000.0" >
                -25383.581  +  299.31255*T  +  -46*T*LN(T)  +  2.29603E+31*T**(-9)
            </range>
        </expression>
        <expression name="Fe#FCC_A1" xsi:type="RangedTemperatureExpr" >
            <range low="298.15" high="1811.0" >
                -1462.4  +  8.282*T  +  -1.15*T*LN(T)  +  6.4E-04*T**2  +  Fe#HSER
            </range>
            <range low="1811.0" high="6000.0" >
                -1713.815  +  0.940009*T  +  Fe#HSER  +  4.9251E+30*T**(-9)
            </range>
        </expression>
        <expression name="Mn#FCC_A1" xsi:type="RangedTemperatureExpr" >
            <range low="298.15" high="1519.0">
                -3439.3  +  131.884*T  +  -24.5177*T*LN(T)0.006*T**2  +  69600*T**(-1)
            </range>
            <range low="1519.0" high="2000.0">
                +2663.31  +  -2.5984*T  +  Mn#HSER  +  2.205113E+30*T**(-9)
            </range>
        </expression>
        <expression name="Mn#HSER" xsi:type="RangedTemperatureExpr" >
            <range low="298.15" high="1519.0">
                -8115.28  +  130.059*T  +  -23.4582*T*LN(T)  +  -0.00734768*T**2  +  69827*T**(-1)
            </range>
            <range low="1519.0" high="2000.0">
                -28733.41  +  312.2648*T  +  -48*T*LN(T)  +  1.656847E+30*T**(-9)
            </range>
        </expression>
        <expression name="C#HSER" xsi:type="RangedTemperatureExpr">
            <range low="298.15" high="6000.0">
                -17368.441  +  170.73*T  +  -24.3*T*LN(T)  +  -4.723E-04*T**2  +  2562600*T**(-1)  +  -2.643E+08*T**(-2)  +  1.2E+10*T**(-3)
            </range>
        </expression>
    </globalExpressions>

</database>
