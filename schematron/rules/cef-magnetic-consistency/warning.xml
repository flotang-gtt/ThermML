        <endmember name="Cr:Va">
          <constituents>
            <site><const species="Cr"/></site>
            <site><const species="Va"/></site>
          </constituents>
          <property xsi:type="G">
            <expr>+1*{GHSERCR}</expr>
          </property>
        </endmember>
        <endmember name="Fe:Va">
