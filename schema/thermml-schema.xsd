<?xml version="1.0" encoding="UTF-8"?>
<xs:schema
    targetNamespace="http://calphad.org/thermml/0.1"
    elementFormDefault="qualified"
    version="0.1"
    xmlns="http://calphad.org/thermml/0.1"
    xmlns:tm="http://calphad.org/thermml/0.1"
    xmlns:xs="http://www.w3.org/2001/XMLSchema">

    <xs:include schemaLocation="simple-types/main.xsd" />
    <xs:include schemaLocation="potentials/main.xsd" />
    <xs:include schemaLocation="system-components/main.xsd" />
    <xs:include schemaLocation="phases/main.xsd" />
    <xs:include schemaLocation="phases/cef-phase.xsd" />
    <xs:include schemaLocation="phases/quasichemical-phase.xsd" />
    <xs:include schemaLocation="databases/main.xsd" />

    <xs:element name="database" type="DatabaseType">
        <xs:key name="systemComponentKey">
            <xs:selector xpath="tm:systemComponents/tm:systemComponent" />
            <xs:field xpath="@symbol" />
        </xs:key>
        <xs:keyref name="phaseStoichiometryComponentMustExist" refer="systemComponentKey">
            <xs:selector xpath="tm:phases/tm:phase/tm:stoichiometry/tm:stoich" />
            <xs:field xpath="@component" />
        </xs:keyref>
        <xs:key name="phaseNameKey">
            <xs:selector xpath="tm:phases/tm:phase" />
            <xs:field xpath="@name" />
        </xs:key>
        <xs:keyref name="orderedPhaseMustReferenceDeclaredDisorderedPhase" refer="phaseNameKey">
            <xs:selector xpath="tm:phases/tm:phase" />
            <xs:field xpath="@disorderedPhase" />
        </xs:keyref>
    </xs:element>

</xs:schema>