<xs:schema
    targetNamespace="http://calphad.org/thermml/0.1"
    elementFormDefault="qualified"
    version="0.1"
    xmlns="http://calphad.org/thermml/0.1"
    xmlns:xs="http://www.w3.org/2001/XMLSchema">

    <xs:include schemaLocation="core.xsd" />
    <xs:include schemaLocation="../expressions/main.xsd" />
    <xs:include schemaLocation="phase-properties.xsd" />
    <xs:include schemaLocation="cef-phase.xsd" />

    <xs:complexType name="CEFOrderedPhaseType">
        <xs:annotation>
            <xs:documentation>An ordered phase based on the CEF model. In the CALPHAD approach,
                ordered phases (e.g., B2, L12) are modeled as a partitioning of the sublattice
                model of a parent disordered phase (e.g., BCC_A2, FCC_A1). The Gibbs energy of
                the ordered phase is computed as G_ordered = G_disordered + delta_G_ordering.
                The disorderedPhase attribute establishes the link to the parent disordered
                phase.</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="CEFPhaseType">
                <xs:attribute name="disorderedPhase" type="NoWhitespaceString" use="required">
                    <xs:annotation>
                        <xs:documentation>Name of the parent disordered phase from which this
                            ordered phase derives. Must match the name attribute of another phase
                            in the database (e.g., "BCC_A2" for a BCC_B2 ordered
                            phase).</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

</xs:schema>
